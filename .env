# Supabase Configuration
# Replace these with your actual Supabase project details. 
# If left empty, the application will fallback to a local SQLite database (workspace.db) automatically.
SUPABASE_URL=""
SUPABASE_KEY=""

# Redis Configuration
# Replace these if using a remote or authenticated Redis server.
# If connection fails or is not installed, the application falls back to an in-memory emulator.
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Session Configuration
JWT_SECRET="super-secret-workspace-key-change-in-production-12345"
SESSION_EXPIRE_SECONDS=7200
